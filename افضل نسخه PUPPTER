// دالة لتأخير التنفيذ
const delay = (ms) => new Promise(resolve => setTimeout(resolve, ms));

// دالة لجلب تفاصيل `inventory_quantity` من صفحة المنتج باستخدام Puppeteer
const getInventoryDetails = async (page, url) => {
  try {
    // تعيين User-Agent ورؤوس HTTP لتقليد متصفح حقيقي
    const userAgent = new UserAgent();
    await page.setUserAgent(userAgent.toString());

    await page.setExtraHTTPHeaders({
      'Accept-Language': 'en-US,en;q=0.9',
    });

    // الانتقال إلى صفحة المنتج
    await page.goto(url, { waitUntil: 'networkidle2' });

    // محاكاة بعض التفاعلات
    await page.mouse.move(100, 100);
    await delay(500); // استخدم دالة delay بدلاً من waitForTimeout إذا كانت غير متاحة
    await page.mouse.click(100, 100);

    // الانتظار حتى يتم تحميل السكربتات (تعديل حسب الحاجة)
    await page.waitForSelector('script');

    // استخراج محتوى الصفحة
    const pageContent = await page.content();

    // استخدام Cheerio لتحليل محتوى الصفحة
    const $ = cheerio.load(pageContent);
    let inventoryQuantity = null;

    $('script').each((i, script) => {
      const scriptContent = $(script).html();

      if (scriptContent && scriptContent.includes('inventory_quantity')) {
        const parts = scriptContent.split('inventory_quantity');
        if (parts.length > 1) {
          const afterInventory = parts[1];
          const match = afterInventory.match(/:\s*(-?\d+)/);
          if (match) {
            inventoryQuantity = parseInt(match[1], 10);
          }
        }
      }
    });

    return inventoryQuantity;
  } catch (error) {
    console.error(`Error fetching inventory from ${url}:`, error.message);
    return null;
  }
};

// تخزين الكميات الحالية للمستخدمين
const currentInventory = {};

// دالة لفحص الصفحة الرئيسية وجلب روابط المنتجات
async function checkHomePage(browser) {
  try {
    const url = 'https://www.dzrt.com/en-sa/products';

    // إنشاء صفحة جديدة
    const page = await browser.newPage();

    // تعيين User-Agent ورؤوس HTTP لتقليد متصفح حقيقي
    const userAgent = new UserAgent();
    await page.setUserAgent(userAgent.toString());

    await page.setExtraHTTPHeaders({
      'Accept-Language': 'en-US,en;q=0.9',
    });

    // الانتقال إلى صفحة المنتجات
    await page.goto(url, { waitUntil: 'networkidle2' });

    // الانتظار حتى يتم تحميل روابط المنتجات
    await page.waitForSelector('a[href*="/products/"]');

    // استخراج محتوى الصفحة
    const homepageContent = await page.content();
    const $ = cheerio.load(homepageContent);
    const currentTime = Date.now();

    const productUrls = [];

    $('a[href*="/products/"]').each((index, element) => {
      const href = $(element).attr('href');
      const productKey = href.split('/products/')[1];

      // التحقق إذا كان المنتج موجودًا في قائمة المنتجات
      if (products[productKey]) {
        const productUrl = `https://www.dzrt.com${href}`;
        productUrls.push({ key: productKey, url: productUrl });
   //     console.log(`Found product URL: ${productUrl}`);
      }
    });

    await page.close();

    if (productUrls.length === 0) {
      console.warn('No product URLs found on the homepage.');
      return;
    }

    // فتح صفحات المنتجات بشكل متزامن مع حد أقصى من الصفحات المفتوحة في نفس الوقت
    const concurrencyLimit = 0; // عدد الصفحات التي سيتم فتحها في نفس الوقت
    let activePromises = [];

    for (const product of productUrls) {
      const promise = (async () => {
        const { key, url } = product;
    //    console.log(`Checking inventory for product: ${key}`);

        // إنشاء صفحة جديدة أو إعادة استخدام صفحة موجودة
        const productPage = await browser.newPage();
        const inventoryQuantity = await getInventoryDetails(productPage, url);
        await productPage.close();

        console.log(`Inventory for ${key}: ${inventoryQuantity}`);
        currentInventory[key] = inventoryQuantity;

        if (inventoryQuantity === null) {
          console.warn(`Could not fetch inventory for ${key}. Skipping...`);
          return;
        }

        // إضافة تأخير لمدة 500 مللي ثانية بين كل فحص منتج لتقليل التحميل
        await delay(500);

        if (inventoryQuantity > 5) {
          const productInfo = products[key];
          const productNameAr = productInfo.ar;
          const imageUrlAvailable = path.join(__dirname, '..', 'images', `${productInfo.en}.png`);

          // التحقق من وجود الصورة
          if (!fs.existsSync(imageUrlAvailable)) {
            console.error(`Image not found for ${key} at path: ${imageUrlAvailable}`);
            return; // تخطي إرسال الإشعار لهذا المنتج
          }

          const messageAvailable = `
*${productNameAr}* - متوفر الآن ✅
المخزون : ${inventoryQuantity}`;

          const replyMarkup = {
            inline_keyboard: [
              [
                { text: 'شراء سريع ⚡', url: 'https://www.dzrt.com/ar-sa/checkout' },
                { text: 'المنتـج 🟢', url: `${url}` }
              ],
              [
                { text: 'المخزون 📦', callback_data: `inventory_${key}` },
                { text: 'اعادة الطلب 🔁', url: 'https://www.dzrt.com/ar-sa/profile/orders' }
              ],
              [
                { text: 'تسجيل دخول 🔒', url: 'https://www.dzrt.com/ar-sa/login' }
              ]
            ]
          };

          // إرسال الإشعار فقط إذا لم يكن المنتج متاحًا من قبل ولم يتم قفل الإشعارات
          if (!productStatus[key].isAvailable && !productStatus[key].notificationLock) {
            console.log(`${productNameAr} ✅ - المنتج متوفر الآن`);

            productStatus[key].isAvailable = true;
            productStatus[key].availableStartTime = currentTime;

            if (!productStatus[key].isNotifying) {
              productStatus[key].isNotifying = true;

              try {
                // إرسال الصورة إلى القنوات المحددة
                await bot.sendPhoto(productInfo.chatId, imageUrlAvailable, {
                  caption: messageAvailable,
                  parse_mode: 'Markdown',
                  reply_markup: JSON.stringify(replyMarkup)
                });

                // إرسال الصورة إلى القناة الرئيسية
                await bot.sendPhoto(mainChannelId, imageUrlAvailable, {
                  caption: messageAvailable,
                  parse_mode: 'Markdown',
                  reply_markup: JSON.stringify(replyMarkup)
                });

                console.log(`Notifications sent for ${productNameAr}`);
              } catch (sendError) {
                console.error(`Error sending notifications for ${productNameAr}:`, sendError.message);
              }

              productStatus[key].isNotifying = false;
            }
          }
        } else {
          const productInfo = products[key];
          const productNameAr = productInfo.ar;
          const imageUrlUnAvailable = path.join(__dirname, '..', 'images', `${productInfo.en}-outofstock.png`); // مسار الصورة عند نفاذ المخزون

          // إذا كانت الكمية 0 أو أقل، نعتبر المنتج غير متوفر
          if (inventoryQuantity <= 0) {
            if (productStatus[key].isAvailable) {
              console.log(`${productNameAr} ❌ - المنتج غير متوفر الآن`);

              productStatus[key].isAvailable = false;

              // حساب المدة التي كان فيها المنتج متوفرًا
              const timeAvailable = currentTime - productStatus[key].availableStartTime;
              const minutesAvailable = Math.floor(timeAvailable / 60000);
              const secondsAvailable = Math.floor((timeAvailable % 60000) / 1000);
              const messageOutOfStock = `نفاذ المنتج *${productNameAr}* ❌ \n\nبقى متوفرا لمدة: ${minutesAvailable} دقائق و ${secondsAvailable} ثواني.`;

              const replyMarkup = {
                inline_keyboard: [
                  [
                    { text: 'إعادة الطلب 🔁', url: 'https://www.dzrt.com/ar-sa/profile/orders' },
                    { text: 'صفحة المنتجات 🛒', url: 'https://www.dzrt.com/ar-sa/products' }
                  ]
                ]
              };

              try {
                // إرسال الصورة إلى القنوات المحددة
                if (fs.existsSync(imageUrlUnAvailable)) {
                  await bot.sendPhoto(productInfo.chatId, imageUrlUnAvailable, {
                    caption: messageOutOfStock,
                    parse_mode: 'Markdown',
                    reply_markup: JSON.stringify(replyMarkup)
                  });

                  // إرسال الصورة إلى القناة الرئيسية
                  await bot.sendPhoto(mainChannelId, imageUrlUnAvailable, {
                    caption: messageOutOfStock,
                    parse_mode: 'Markdown',
                    reply_markup: JSON.stringify(replyMarkup)
                  });

                  console.log(`Out of stock notification sent for ${productNameAr}`);
                } else {
                  console.error(`Out of stock image not found for ${key} at path: ${imageUrlUnAvailable}`);
                }
              } catch (sendError) {
                console.error(`Error sending out of stock notification for ${productNameAr}:`, sendError.message);
              }

              // قفل لإيقاف إرسال الإشعارات لمدة 20 ثانية
              productStatus[key].notificationLock = true;
              setTimeout(() => {
                productStatus[key].notificationLock = false;
                console.log(`Notification lock lifted for ${productNameAr}`);
              }, 20000); // 20 ثانية
            }
          }
        }
      })();

      activePromises.push(promise);

      // إذا تجاوز عدد العمليات المتزامنة الحد المسموح به، انتظر حتى يكتمل أحدها
      if (activePromises.length >= concurrencyLimit) {
        await Promise.race(activePromises);
        activePromises = activePromises.filter(p => !p.isFulfilled && !p.isRejected);
      }
    }

    // انتظار انتهاء جميع العمليات
    await Promise.all(activePromises);

  } catch (error) {
    console.error(`حدث خطأ أثناء فحص الصفحة الرئيسية: ${error.message}`);
  }
}

